# Development configuration
# For production, replace :80 with your domain (e.g., johndusel.com)
# Caddy will automatically provision HTTPS certificates

{$DOMAIN:localhost} {
    # Enable compression
    encode zstd gzip

    # API and admin routes go to Django backend
    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /admin/* {
        reverse_proxy backend:8000
    }

    # Django static files
    handle /static/* {
        reverse_proxy backend:8000
    }

    # Django media files (if not using S3)
    handle /media/* {
        reverse_proxy backend:8000
    }

    # Everything else goes to Next.js frontend
    handle {
        reverse_proxy frontend:3000
    }

    # Logging
    log {
        output stdout
        format console
    }
}
