# johndusel.com Docker Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# GENERAL
# =============================================================================
ENVIRONMENT=production
DOMAIN=johndusel.com
SITE_URL=https://johndusel.com

# =============================================================================
# DJANGO BACKEND
# =============================================================================
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-with-python-secrets
ALLOWED_HOSTS=johndusel.com,www.johndusel.com,localhost,backend

# Database (SQLite by default, or use DATABASE_URL for PostgreSQL)
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# =============================================================================
# AWS S3 (for media uploads)
# =============================================================================
AWS_S3_ACCESS_KEY_ID=
AWS_S3_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=us-east-2

# =============================================================================
# SENTRY (error tracking)
# =============================================================================
SENTRY_DSN=

# =============================================================================
# DJANGO SUPERUSER (created on first run)
# =============================================================================
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_PASSWORD=changeme
DJANGO_SUPERUSER_EMAIL=admin@example.com
